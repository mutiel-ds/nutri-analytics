# Credenciales de Supabase (Dashboard > Settings > API Keys)
# Copia este archivo a .env y rellena tus valores. NUNCA subas .env a git.
SUPABASE_URL=https://tu-proyecto.supabase.co

# Secret key (sb_secret_...): la que usa la app; ignora RLS. No uses las claves legacy.
SUPABASE_SECRET_KEY=sb_secret_...

# Publishable key (sb_publishable_...): opcional, la app no la usa por ahora.
# Sujeta a RLS (sin políticas no tiene acceso a nada); es segura de compartir.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
